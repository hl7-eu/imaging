@startuml ehds-actors-usecases

skinparam backgroundColor white
skinparam handwritten false
skinparam defaultFontSize 10
skinparam wrapWidth 200

skinparam actor {
  BorderColor #333333
  FontStyle bold
}

skinparam usecase {
  BorderThickness 2
  FontSize 9
}

skinparam note {
  FontSize 9
}

left to right direction

' ==================== ACCESSOR USE CASES ====================
usecase "**Search**\n(Health Professional)\n--\n//Identify patient by://\nid, name, birthday, country\n//Seek reports by://\nbody part, date/time, modality,\ninstitution, country" as UC_SearchHP #DAE8FC

usecase "**Search**\n(Patient)\n--\n//Patient searches own reports by://\ninstitution, country, anatomical\nregion, modality, date/time" as UC_SearchPatient #DAE8FC

usecase "**Access**\n--\nAccess selected imaging\nreport(s)" as UC_Access #DAE8FC

' Out of scope - imaging study access
usecase "**Access Imaging Study** *\n--\n//Out of Scope://\nAccessing referenced imaging\nstudy from report.\nThis is tackled in the MADO profile." as UC_AccessStudy #F5F5F5

' ==================== PROCESSOR USE CASES ====================
usecase "**Extract & Process Coded Data**\n--\nExtract structured/coded findings,\nmeasurements, impressions\n(Registries, AI tools, Clinical\nDecision Support)\n--\n**Requires coded Observations/Conditions**" as UC_Processing #D5E8D4

' ==================== DISPLAYER USE CASES ====================
usecase "**Render Static Report**\n--\nDisplay pre-rendered report\n(PDF, HTML, or other static format)\n--\nNo dynamic UI population needed" as UC_RenderStatic #FFE6CC

usecase "**Dynamically Populate UI**\n--\nExtract and display narrative sections,\nfindings, measurements in\nlocal UI components\n--\n**Requires structured narrative**" as UC_DynamicDisplay #FFE6CC

usecase "**Translate to Local Language**\n--\nTranslate coded values and\nterminology to local language" as UC_Translation #FFE6CC

' ==================== CREATOR USE CASES ====================
usecase "**Reporting**\n--\nVerify correct patient, date/time,\naccess DICOM header info,\nconsider clinical question/reason,\nwrite report in assigned system" as UC_Reporting #F8CECC

' ==================== ACTORS ====================
actor "Accessor" as Accessor #DAE8FC
actor "Processor" as Processor #D5E8D4
actor "Displayer\n(Patient or Healthcare Professional)" as Displayer #FFE6CC
actor "Creator" as Creator #F8CECC

' ==================== ACTOR ASSOCIATIONS ====================
Accessor --> UC_SearchHP
Accessor --> UC_SearchPatient
Accessor --> UC_Access

Processor --> UC_Processing

Displayer --> UC_RenderStatic
Displayer --> UC_DynamicDisplay

Creator --> UC_Reporting

' ==================== INCLUDE RELATIONSHIPS ====================
' Search includes Access
UC_SearchHP ..> UC_Access : <<include>>
UC_SearchPatient ..> UC_Access : <<include>>

' ==================== GENERALIZATION RELATIONSHIPS ====================

' ==================== EXTEND RELATIONSHIPS (OUT OF SCOPE) ====================
UC_AccessStudy ..> UC_Processing : <<extend>>
UC_AccessStudy ..> UC_RenderStatic : <<extend>>
UC_AccessStudy ..> UC_DynamicDisplay : <<extend>>
UC_Translation ..> UC_DynamicDisplay : <<extend>>

' ==================== NOTES ====================
note bottom of UC_AccessStudy
  * **Out of Scope** for this IG
  This is addressed in the MADO profile
end note

@enduml
