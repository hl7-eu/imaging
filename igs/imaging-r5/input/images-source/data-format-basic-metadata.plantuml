@startuml data-format-basic-metadata

skinparam backgroundColor white
skinparam handwritten false
skinparam defaultFontSize 10
skinparam classAttributeFontSize 9

skinparam class {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
}

class "DocumentReferenceImagingReport\n<<DocumentReference>>" as DocumentReferenceImagingReport [[./StructureDefinition-DocumentReferenceImagingReport.html]] {
  +subject : Reference~Patient~
  +date : dateTime
  +type : CodeableConcept
  +category : CodeableConcept
  +content : Attachment(url -> Bundle)
  ...
}

class "BundleReportMinimalMetadataEuImaging\n<<Bundle>>" as BundleReportMinimalMetadataEuImaging [[./StructureDefinition-BundleReportMinimalMetadataEuImaging.html]] {
  +type : #collection
}

class "DiagnosticReportEuImagingMinimalMetadata\n<<DiagnosticReport>>" as DiagnosticReportEuImagingMinimalMetadata [[./StructureDefinition-DiagnosticReportEuImagingMinimalMetadata.html]] {
  +presentedForm : Attachment~PDF~
  +basedOn : Reference~ServiceRequest~ (or identifier)
  +study/imagingStudy : Reference~ImagingStudy~ (or identifier)
  ...
}

class "ImagingStudyEuImaging\n<<ImagingStudy>>" as ImagingStudyEuImaging [[./StructureDefinition-ImagingStudyEuImaging.html]] {
  +identifier : StudyInstanceUidIdentifierEuImaging
  ...
}

class "ServiceRequestOrderEuImaging\n<<ServiceRequest>>" as ServiceRequestOrderEuImaging [[./StructureDefinition-ServiceRequestOrderEuImaging.html]] {
  +identifier : AccessionNumberIdentifierEuImaging
  ...
}

class "BinaryUnstructuredReport\n<<Binary>>" as BinaryUnstructuredReport [[./Binary-BinaryUnstructuredReport.html]] {
  +contentType : "application/pdf"
  +data : base64Binary
}

DocumentReferenceImagingReport --> BundleReportMinimalMetadataEuImaging : content.attachment.url
BundleReportMinimalMetadataEuImaging --> DiagnosticReportEuImagingMinimalMetadata : entry
BundleReportMinimalMetadataEuImaging --> ImagingStudyEuImaging : entry (optional)
BundleReportMinimalMetadataEuImaging --> ServiceRequestOrderEuImaging : entry (optional)
DiagnosticReportEuImagingMinimalMetadata --> BinaryUnstructuredReport : presentedForm
DiagnosticReportEuImagingMinimalMetadata --> ImagingStudyEuImaging : study/imagingStudy
DiagnosticReportEuImagingMinimalMetadata --> ServiceRequestOrderEuImaging : basedOn

note right of DiagnosticReportEuImagingMinimalMetadata
R4 element name: imagingStudy
R5 element name: study
end note

note right of DocumentReferenceImagingReport
R4 content profile is carried in
content.extension[profile].extension[value].valueCanonical

R5 content profile is carried in
content.profile[...].valueCanonical
end note

@enduml
